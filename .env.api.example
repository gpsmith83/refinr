# API runtime
PORT=3001

# Database
# Prefer this single URL for services.
DATABASE_URL=postgres://refinr:refinr@localhost:5432/refinr

# Sessions
SESSION_SECRET=replace-me
SESSION_COOKIE_NAME=refinr_session
