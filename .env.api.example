# GitHub OAuth (B-004)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Linear integration (later milestones)
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

# AI provider (later milestones)
AI_PROVIDER=openai
OPENAI_API_KEY=
